# ─────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────
# Obtén tu URL de conexión en Railway, Supabase o Neon
DATABASE_URL="postgresql://usuario:contraseña@host:5432/chambape?schema=public"

# ─────────────────────────────────────────
# CLERK — AUTENTICACIÓN
# ─────────────────────────────────────────
# Crea tu app en https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# URLs de redirección después de login/registro
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/iniciar-sesion"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/registrarse"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/registrarse/tipo"

# Webhook secret de Clerk (para sincronizar usuarios a DB)
# Encuéntralo en Dashboard > Webhooks > tu endpoint
CLERK_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────
# CLOUDINARY — ALMACENAMIENTO DE IMÁGENES
# ─────────────────────────────────────────
# Crea cuenta gratuita en https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# ─────────────────────────────────────────
# CULQI — PASARELA DE PAGO PERUANA
# ─────────────────────────────────────────
# Solicita acceso en https://culqi.com
NEXT_PUBLIC_CULQI_PUBLIC_KEY="pk_test_..."
CULQI_PRIVATE_KEY="sk_test_..."
# Token de autenticación para webhooks (configúralo en Culqi Panel > Webhooks > Activar autenticación)
CULQI_WEBHOOK_SECRET="tu-token-secreto-aqui"

# ─────────────────────────────────────────
# MERCADOPAGO — PASARELA DE PAGO
# ─────────────────────────────────────────
# Obtén tu Access Token en https://www.mercadopago.com.pe/developers/panel/app
# Usa el token de PRODUCCIÓN para pagos reales
MP_ACCESS_TOKEN="APP_USR-..."
# Opcional: secreto para verificar firma de webhooks
MP_WEBHOOK_SECRET="tu-secreto-webhook-mp"

# ─────────────────────────────────────────
# RESEND — ENVÍO DE EMAILS
# ─────────────────────────────────────────
# Crea cuenta gratuita en https://resend.com (100 emails/día gratis)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="ChambaPe <hola@chambape.pe>"

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# En producción: NEXT_PUBLIC_APP_URL="https://chambape.pe"

# ─────────────────────────────────────────
# ADMIN
# ─────────────────────────────────────────
# Email del administrador principal (se asigna rol ADMIN automáticamente)
ADMIN_EMAIL="admin@chambape.pe"
