generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String               @id @default(cuid())
  clerkId                   String               @unique
  email                     String               @unique
  phone                     String?
  name                      String
  role                      UserRole             @default(CLIENT)
  avatarUrl                 String?
  active                    Boolean              @default(true)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  clientConversations       Conversation[]       @relation("ClientConversations")
  professionalConversations Conversation[]       @relation("ProfessionalConversations")
  favorites                 Favorite[]
  sentMessages              Message[]            @relation("SentMessages")
  notifications             Notification[]
  professionalProfile       ProfessionalProfile?
  reviewsGiven              Review[]             @relation("ClientReviews")
  requests                  ServiceRequest[]     @relation("ClientRequests")

  @@map("users")
}

model ProfessionalProfile {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  dni                String                    @unique
  dniFrontUrl        String?
  dniBackUrl         String?
  selfieDniUrl       String?
  bio                String?
  avatarUrl          String?
  districts          String[]
  avgRating          Float                     @default(0)
  totalJobs          Int                       @default(0)
  credits            Int                       @default(0)
  status             ProfessionalStatus        @default(PENDING_VERIFICATION)
  verifiedAt         DateTime?
  rejectionReason    String?
  onboardingStep     Int                       @default(1)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  creditTransactions CreditTransaction[]
  favoritedBy        Favorite[]
  portfolioImages    PortfolioImage[]
  badges             ProfessionalBadge[]
  categories         ProfessionalCategory[]
  documents          ProfessionalDocument[]
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription       ProfessionalSubscription?
  reviewsReceived    Review[]                  @relation("ProfessionalReviews")
  applications       ServiceApplication[]
  directRequests     ServiceRequest[]          @relation("DirectRequests")
  workExperiences    WorkExperience[]

  @@map("professional_profiles")
}

model ServiceCategory {
  id            String                 @id @default(cuid())
  name          String
  slug          String                 @unique
  icon          String
  description   String?
  creditCost    Int                    @default(5)
  active        Boolean                @default(true)
  order         Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  professionals ProfessionalCategory[]
  requests      ServiceRequest[]
  subcategories ServiceSubcategory[]

  @@map("service_categories")
}

model ServiceSubcategory {
  id         String           @id @default(cuid())
  categoryId String
  name       String
  slug       String           @unique
  active     Boolean          @default(true)
  order      Int              @default(0)
  createdAt  DateTime         @default(now())
  requests   ServiceRequest[]
  category   ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("service_subcategories")
}

model ProfessionalCategory {
  professionalId String
  categoryId     String
  assignedAt     DateTime            @default(now())
  category       ServiceCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@id([professionalId, categoryId])
  @@map("professional_categories")
}

model ServiceRequest {
  id                   String               @id @default(cuid())
  clientId             String
  categoryId           String
  subcategoryId        String?
  title                String
  description          String
  photos               String[]
  district             String
  urgency              Urgency              @default(FLEXIBLE)
  budgetMin            Int?
  budgetMax            Int?
  preferredTime        String?
  status               RequestStatus        @default(OPEN)
  maxApplications      Int                  @default(5)
  viewCount            Int                  @default(0)
  expiresAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  address              String?
  latitude             Float?
  longitude            Float?
  targetProfessionalId String?
  review               Review?
  applications         ServiceApplication[]
  category             ServiceCategory      @relation(fields: [categoryId], references: [id])
  client               User                 @relation("ClientRequests", fields: [clientId], references: [id])
  subcategory          ServiceSubcategory?  @relation(fields: [subcategoryId], references: [id])
  targetProfessional   ProfessionalProfile? @relation("DirectRequests", fields: [targetProfessionalId], references: [id])

  @@map("service_requests")
}

model ServiceApplication {
  id             String              @id @default(cuid())
  requestId      String
  professionalId String
  message        String
  proposedBudget Int?
  creditsSpent   Int
  status         ApplicationStatus   @default(PENDING)
  acceptedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  review         Review?
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])
  request        ServiceRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, professionalId])
  @@map("service_applications")
}

model Review {
  id                  String              @id @default(cuid())
  requestId           String              @unique
  applicationId       String              @unique
  clientId            String
  professionalId      String
  rating              Int
  comment             String
  professionalReply   String?
  repliedAt           DateTime?
  reportedBy          String?
  reportReason        String?
  moderatedAt         DateTime?
  hidden              Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  clientRatingComment String?
  clientRatingScore   Int?
  application         ServiceApplication  @relation(fields: [applicationId], references: [id])
  client              User                @relation("ClientReviews", fields: [clientId], references: [id])
  professional        ProfessionalProfile @relation("ProfessionalReviews", fields: [professionalId], references: [id])
  request             ServiceRequest      @relation(fields: [requestId], references: [id])

  @@map("reviews")
}

model CreditPackage {
  id        String   @id @default(cuid())
  name      String
  credits   Int
  pricePen  Int
  savings   String?
  popular   Boolean  @default(false)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("credit_packages")
}

model SubscriptionPlan {
  id              String                     @id @default(cuid())
  mpPlanId        String?                    @unique
  name            String
  creditsPerMonth Int
  pricePen        Int
  active          Boolean                    @default(true)
  features        String[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  subscriptions   ProfessionalSubscription[]

  @@map("subscription_plans")
}

model ProfessionalSubscription {
  id               String              @id @default(cuid())
  professionalId   String              @unique
  planId           String
  mpSubscriptionId String?             @unique
  status           SubscriptionStatus  @default(ACTIVE)
  nextBillingDate  DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  plan             SubscriptionPlan    @relation(fields: [planId], references: [id])
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("professional_subscriptions")
}

model CreditTransaction {
  id             String              @id @default(cuid())
  professionalId String
  type           TransactionType
  credits        Int
  amountPen      Int?
  balance        Int
  description    String
  packageId      String?
  requestId      String?
  culqiChargeId  String?
  metadata       Json?
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])

  @@map("credit_transactions")
}

model PortfolioImage {
  id             String              @id @default(cuid())
  professionalId String
  url            String
  caption        String?
  order          Int                 @default(0)
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("portfolio_images")
}

model Badge {
  id            String              @id @default(cuid())
  slug          String              @unique
  name          String
  description   String
  icon          String
  professionals ProfessionalBadge[]

  @@map("badges")
}

model ProfessionalBadge {
  professionalId String
  badgeId        String
  awardedAt      DateTime            @default(now())
  badge          Badge               @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@id([professionalId, badgeId])
  @@map("professional_badges")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Conversation {
  id                 String    @id @default(cuid())
  clientId           String
  professionalUserId String
  lastMessageAt      DateTime  @default(now())
  createdAt          DateTime  @default(now())
  client             User      @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  professionalUser   User      @relation("ProfessionalConversations", fields: [professionalUserId], references: [id], onDelete: Cascade)
  messages           Message[]

  @@unique([clientId, professionalUserId])
  @@map("conversations")
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  fileUrl        String?
  fileType       MessageFileType?
  fileName       String?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model WorkExperience {
  id             String              @id @default(cuid())
  professionalId String
  company        String
  role           String
  startYear      Int
  endYear        Int?
  description    String?
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("work_experiences")
}

model ProfessionalDocument {
  id             String              @id @default(cuid())
  professionalId String
  type           DocumentType
  title          String
  fileUrl        String
  isPublic       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("professional_documents")
}

model Favorite {
  id             String              @id @default(cuid())
  userId         String
  professionalId String
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, professionalId])
  @@map("favorites")
}

enum UserRole {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum ProfessionalStatus {
  PENDING_VERIFICATION
  VERIFIED
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum TransactionType {
  PURCHASE
  SPEND
  REFUND
  BONUS
  SUBSCRIPTION_PAYMENT
}

enum NotificationType {
  NEW_APPLICATION
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  NEW_REQUEST
  LOW_CREDITS
  CREDITS_PURCHASED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  NEW_REVIEW
  REVIEW_REPLY
  REQUEST_EXPIRED
  NEW_MESSAGE
}

enum DocumentType {
  CV
  CERTIFICATE
  CRIMINAL_RECORD
}

enum MessageFileType {
  IMAGE
  PDF
  AUDIO
  OTHER
}

enum Urgency {
  TODAY
  THIS_WEEK
  THIS_MONTH
  FLEXIBLE
}
